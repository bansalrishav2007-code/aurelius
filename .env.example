# Aureliuss — Environment Variables

# OpenAI — AI copilot (GPT-4o, server-side only — never expose in client code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional overrides:
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=120000

# Founder Super Admin (permanent — change password in production)
AURELIUSS_FOUNDER_PASSWORD=aureliuss-founder-dev-change-me

# Admin panel access (change in production)
AURELIUSS_ADMIN_KEY=aureliuss-dev-admin-change-me

# Razorpay subscriptions (optional — dev mode returns mock orders)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Invitation emails (Resend — optional in dev; logs to console without key)
RESEND_API_KEY=
AURELIUSS_EMAIL_FROM=Aureliuss Private <invitations@aureliuss.com>
AURELIUSS_APP_URL=http://localhost:8080

# Node environment
NODE_ENV=development
